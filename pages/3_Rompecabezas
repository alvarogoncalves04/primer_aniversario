# ========== FUNCIÓN PARA MOSTRAR UN ROMPECABEZAS ==========
def mostrar_rompecabezas(nivel, config):
    st.subheader(f"🧩 {config['nombre']}")
    
    # Mostrar imagen de referencia (pequeña)
    try:
        img_ref = Image.open(config["foto"])
        st.image(img_ref, caption="🌸 Esta es la imagen que debes armar", width=200)
    except:
        st.warning(f"⚠️ No se encontró la imagen: {config['foto']}")
    
    st.markdown(f"*{config['descripcion']}*")
    st.caption("💡 Recuerda: Las piezas van en orden del 1 al 9, de izquierda a derecha, fila por fila.")
    
    st.markdown("---")
    
    if not config["completado"]:
        pieza_actual = config["piezas_encontradas"] + 1
        st.markdown(f"### 🔢 Busca la pieza número **{pieza_actual}**")
        
        # Mostrar las piezas en una cuadrícula 3x3
        cols = st.columns(3)
        for idx, pos in enumerate(config["orden_piezas"]):
            if not config["piezas_correctas"][pos]:
                with cols[idx % 3]:
                    if pos + 1 == pieza_actual:
                        if st.button(f"🧩 Pieza {pos + 1}", key=f"nivel{nivel}_pieza_{pos}", use_container_width=True):
                            config["piezas_correctas"][pos] = True
                            config["piezas_encontradas"] += 1
                            # Actualizar session_state
                            if nivel == 1:
                                st.session_state.piezas_encontradas_nivel1 = config["piezas_encontradas"]
                                st.session_state.piezas_correctas_nivel1 = config["piezas_correctas"]
                            elif nivel == 2:
                                st.session_state.piezas_encontradas_nivel2 = config["piezas_encontradas"]
                                st.session_state.piezas_correctas_nivel2 = config["piezas_correctas"]
                            else:
                                st.session_state.piezas_encontradas_nivel3 = config["piezas_encontradas"]
                                st.session_state.piezas_correctas_nivel3 = config["piezas_correctas"]
                            st.rerun()
                    else:
                        st.button(f"🔒 Pieza {pos + 1}", key=f"block_{nivel}_{pos}", disabled=True, use_container_width=True)
        
        # Mostrar progreso del nivel
        st.progress(config["piezas_encontradas"] / 9, text=f"Progreso: {config['piezas_encontradas']} de 9 piezas")
        
        # Verificar si completó este nivel
        if config["piezas_encontradas"] == 9:
            if nivel == 1:
                st.session_state.nivel1_completado = True
            elif nivel == 2:
                st.session_state.nivel2_completado = True
            else:
                st.session_state.nivel3_completado = True
            st.balloons()
            st.success(f"🎉 ¡COMPLETASTE {config['nombre']}! 🎉")
            if nivel < 3:
                st.info(f"✨ ¡Nivel {nivel + 1} desbloqueado! Sigue hacia abajo. ✨")
            st.rerun()
    else:
        # Nivel completado
        st.markdown(f"""
        <div class="completado-card">
            <h3>✅ ¡{config['nombre']} COMPLETADO! ✅</h3>
            <p>✨ Ya puedes continuar con el siguiente nivel ✨</p>
        </div>
        """, unsafe_allow_html=True)
        
        # Mostrar la foto completa al completar
        try:
            img_completa = Image.open(config["foto"])
            st.image(img_completa, caption=f"💖 {config['nombre']} - ¡LO LOGRASTE! 💖", use_container_width=True)
        except:
            pass

    st.divider()

